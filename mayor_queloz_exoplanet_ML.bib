@book{Holland1975,
  author    = {Holland, John H.},
  title     = {Adaptation in Natural and Artificial Systems:
               An Introductory Analysis with Applications to Biology,
               Control, and Artificial Intelligence},
  publisher = {University of Michigan Press},
  address   = {Ann Arbor},
  year      = {1975},
  note      = {Second edition: MIT Press, Cambridge MA, 1992.
               Introduces the genetic algorithm as a method for
               adaptive search over high-dimensional parameter spaces,
               formalising Darwin's natural selection as a
               probabilistic optimisation procedure.}
}

@book{Goldberg1989,
  author    = {Goldberg, David E.},
  title     = {Genetic Algorithms in Search, Optimization, and
               Machine Learning},
  publisher = {Addison-Wesley},
  address   = {Reading, MA},
  year      = {1989},
  note      = {The standard textbook treatment of Holland's
               genetic algorithm and its applications.  Discusses
               binary and real-valued encodings, crossover operators,
               mutation rates, and convergence theory.}
}

@article{Charbonneau1995,
  author  = {Charbonneau, Paul},
  title   = {Genetic Algorithms in Astronomy and Astrophysics},
  journal = {Astrophysical Journal Supplement Series},
  volume  = {101},
  pages   = {309--334},
  year    = {1995},
  doi     = {10.1086/192242},
  note    = {Introduces \textsc{Pikaia}, a floating-point genetic
             algorithm code implementing Holland's framework,
             specifically tailored for astrophysical fitting problems.
             Demonstrates applications to spectral-line profile
             fitting and solar magnetic field inversion.  \textsc{Pikaia}
             was widely adopted in the exoplanet radial-velocity community
             for orbital fitting, where the likelihood surface is
             strongly multimodal in period space.}
}

@article{Mayor1995,
  author  = {Mayor, Michel and Queloz, Didier},
  title   = {A {J}upiter-mass companion to a solar-type star},
  journal = {Nature},
  volume  = {378},
  pages   = {355--359},
  year    = {1995},
  doi     = {10.1038/378355a0},
  note    = {The discovery paper for 51~Pegasi~b, the first
             confirmed exoplanet orbiting a main-sequence star.
             Reports $P = 4.2308$~days, $K = 56.0$~m/s,
             $e \approx 0$, $m_p\sin i \approx 0.47\,M_J$ from
             \textsc{Elodie} radial velocity measurements.
             Nobel Prize in Physics, 2011 (Mayor and Queloz, shared).}
}

@article{Baranne1996,
  author  = {Baranne, A. and Queloz, D. and Mayor, M. and Adrianzyk, G.
             and Knispel, G. and Kohler, D. and Lacroix, D.
             and Meunier, J.-P. and Rimbaud, G. and Vin, A.},
  title   = {{ELODIE}: A spectrograph for accurate radial velocity
             measurements},
  journal = {Astronomy and Astrophysics Supplement Series},
  volume  = {119},
  pages   = {373--390},
  year    = {1996},
  doi     = {10.1051/aas:1996251},
  note    = {Instrument paper for the \textsc{Elodie} fiber-fed
             echelle spectrograph at the Observatoire de
             Haute-Provence 1.93~m telescope.  Documents the
             cross-correlation method, simultaneous thorium-argon
             wavelength calibration, and the $\approx 13$~m/s
             single-measurement precision that led to the 51~Peg
             discovery.}
}

@article{Marcy1996,
  author  = {Marcy, Geoffrey W. and Butler, R. Paul},
  title   = {A Planetary Companion to 70~{V}irginis},
  journal = {Astrophysical Journal Letters},
  volume  = {464},
  pages   = {L147--L151},
  year    = {1996},
  doi     = {10.1086/310096},
  note    = {Independent confirmation of the planetary interpretation
             of radial-velocity signals, by the California group
             using the Hamilton echelle spectrograph at Lick Observatory.
             Their simultaneous discovery of 47~Uma~b (Butler \&\ Marcy
             1996, ApJL 464, L153) established the new class of
             ``hot Jupiters'' and validated the Geneva group's techniques.}
}

@article{Butler1996,
  author  = {Butler, R. Paul and Marcy, Geoffrey W. and Williams, Eric
             and McCarthy, Chris and Dosanjh, Prgeeta and Vogt, Steven S.},
  title   = {Attaining {D}oppler Precision of 3~{m/s}},
  journal = {Publications of the Astronomical Society of the Pacific},
  volume  = {108},
  pages   = {500--509},
  year    = {1996},
  doi     = {10.1086/133751},
  note    = {Describes the iodine-cell technique used by the California
             group to achieve $\sim 3$~m/s radial velocity precision
             with the Lick Hamilton spectrograph.  The iodine cell
             imprints a dense forest of absorption lines simultaneously
             on every stellar spectrum, enabling a self-calibrating
             wavelength solution independent of a secondary lamp.}
}

@article{Lomb1976,
  author  = {Lomb, Nick R.},
  title   = {Least-squares frequency analysis of unequally spaced data},
  journal = {Astrophysics and Space Science},
  volume  = {39},
  pages   = {447--462},
  year    = {1976},
  doi     = {10.1007/BF00648343},
  note    = {Develops the Lomb periodogram for unevenly sampled time
             series, equivalent to a least-squares fit of a sinusoid
             at each trial frequency.  The standard tool for identifying
             candidate orbital periods in radial velocity data;
             however, it assumes circular orbits and a single sinusoidal
             signal---limitations that motivate the genetic algorithm
             for eccentric or multi-planet systems.}
}

@article{Scargle1982,
  author  = {Scargle, Jeffrey D.},
  title   = {Studies in astronomical time series analysis.
             {II.}\ Statistical aspects of spectral analysis of
             unevenly spaced data},
  journal = {Astrophysical Journal},
  volume  = {263},
  pages   = {835--853},
  year    = {1982},
  doi     = {10.1086/160554},
  note    = {Provides the statistical framework for the Lomb
             periodogram, deriving the false alarm probability (FAP)
             under the null hypothesis of pure Gaussian noise.
             Establishes that the normalised power $z_{\rm max}$ has
             an exponential distribution under $H_0$, enabling
             significance assessment for putative periodic signals.
             For 51~Peg~b the FAP $< 10^{-9}$.}
}

@article{Cumming1999,
  author  = {Cumming, Andrew and Marcy, Geoffrey W. and Butler, R. Paul},
  title   = {The {L}ick Planet Search: Detectability and Mass Thresholds},
  journal = {Astrophysical Journal},
  volume  = {526},
  pages   = {890--915},
  year    = {1999},
  doi     = {10.1086/308020},
  note    = {Develops the likelihood ratio periodogram extending the
             Lomb-Scargle formalism to eccentric orbits.  Shows that
             the floating-mean periodogram and the $F$-ratio statistic
             provide more sensitive detection for eccentric and
             multi-planet systems than the sinusoidal Lomb-Scargle
             periodogram.}
}

