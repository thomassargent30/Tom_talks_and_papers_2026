@article{Walker1995,
  author  = {Walker, Gordon A. H. and Walker, A. R. and Irwin, A. W.
             and Larson, A. M. and Yang, S. L. S. and
             Richardson, D. C.},
  title   = {A search for {J}upiter-mass companions to nearby stars},
  journal = {Icarus},
  volume  = {116},
  pages   = {359--375},
  year    = {1995},
  doi     = {10.1006/icar.1995.1130},
  note    = {Reports 12 years of radial velocity monitoring of 21
             solar-type stars with the Victoria spectrograph, achieving
             $\approx 13$~m/s precision.  No convincing planetary
             detections, demonstrating the selection pressure for
             improved spectrographs.  An important precursor
             establishing the feasibility of the Doppler method.}
}

@article{Fischer2005,
  author  = {Fischer, Debra A. and Valenti, Jeff},
  title   = {The Planet-Metallicity Correlation},
  journal = {Astrophysical Journal},
  volume  = {622},
  pages   = {1102--1117},
  year    = {2005},
  doi     = {10.1086/428383},
  note    = {Reports that the frequency of gas-giant planets correlates
             strongly with host-star iron abundance: stars with
             $[{\rm Fe/H}] > +0.3$ have a $\approx 25$\% planet
             occurrence rate vs.\ $\approx 3$\% for solar metallicity
             stars.  This structural prediction from the core-accretion
             model could be confirmed only because the radial velocity
             method detected a large enough sample.}
}

@article{Queloz2001,
  author  = {Queloz, D. and Henry, G. W. and Sivan, J. P. and
             Baliunas, S. L. and Beuzit, J. L. and Donahue, R. A.
             and Mayor, M. and Naef, D. and Perrier, C. and
             Udry, S.},
  title   = {No evidence for planets orbiting
             $\varepsilon$~{E}ridani},
  journal = {Astronomy and Astrophysics},
  volume  = {379},
  pages   = {279--287},
  year    = {2001},
  doi     = {10.1051/0004-6361:20011342},
  note    = {A cautionary example illustrating how stellar activity
             (spots, jitter) can produce periodic radial velocity
             signals mimicking a planet.  The apparent companion to
             $\varepsilon$~Eri was identified as an alias of the
             stellar rotation period.  Motivates the inclusion of
             stellar jitter $\sigma_{\rm jit}$ as a free parameter
             in the likelihood.}
}

@article{Mayor2009,
  author  = {Mayor, Michel and Bonfils, Xavier and Forveille, Thierry
             and Delfosse, Xavier and Udry, St\'ephane and
             Bertaux, J.-L. and Beust, H. and Bouchy,
