  journal = {Astronomy and Astrophysics},
  volume  = {507},
  pages   = {487--494},
  year    = {2009},
  doi     = {10.1051/0004-6361/200912172},
  note    = {Discovery of super-Earth planet GJ~581e with
             $K = 1.87$~m/s and $m_p\sin i = 1.94\, M_\oplus$---a
             mass barely above that of Earth.  Represents the ultimate
             achievement of Mayor's program: the Keplerian likelihood
             plus HARPS precision plus a genetic-algorithm global
             search, applied to a $\approx1$~m/s signal in 119 HARPS
             observations.}
}

@article{Saar1997,
  author  = {Saar, Steven H. and Donahue, Robert A.},
  title   = {Activity-related Radial Velocity Variation in Cool Stars},
  journal = {Astrophysical Journal},
  volume  = {485},
  pages   = {319--327},
  year    = {1997},
  doi     = {10.1086/304392},
  note    = {Quantifies the amplitude of radial velocity ``jitter''
             induced by stellar surface activity: magnetic spots,
             plages, and oscillations.  For a solar-type star with
             low activity, $\sigma_{\rm jit} \approx 2$--$5$~m/s.
             For active stars, $\sigma_{\rm jit}$ can reach 50~m/s,
             masking or mimicking planetary signals.}
}

@article{Baluev2008,
