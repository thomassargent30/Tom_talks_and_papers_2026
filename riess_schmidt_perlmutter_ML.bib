  pages   = {88--109},
  year    = {1996},
  doi     = {10.1086/178129},
  note    = {Develops the Multi-Light-Curve Shape (MLCS) method,
             which simultaneously fits multi-band light curves with
             a template family parameterised by a single luminosity
             offset~$\Delta$.  Reduces intrinsic SN Ia scatter to
