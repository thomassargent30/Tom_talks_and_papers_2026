@article{Phillips1993,
  author  = {Phillips, Mark M.},
  title   = {The absolute magnitudes of {T}ype {I}a supernovae},
  journal = {Astrophysical Journal Letters},
  volume  = {413},
  pages   = {L105--L108},
  year    = {1993},
  doi     = {10.1086/186970},
  note    = {Establishes the width--luminosity relation for Type Ia
             supernovae: events that decline faster ($\Delta m_{15}$
             larger) are intrinsically fainter.  The $\Delta m_{15}$
             parameter reduces the intrinsic dispersion of SN Ia peak
             magnitudes from $\approx 0.4$~mag to $\approx 0.17$~mag.
             This is the analogue of Lenard's discovery that frequency,
             not intensity, controls the photoelectric stopping potential.}
}

