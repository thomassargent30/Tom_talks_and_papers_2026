% pauli_exclusion_ML.bib
% Bibliography for "Pauli's Heuristic as Statistical Inference:
%   The Exclusion Principle as a Parsimonious Four-Parameter Model"

% ---------------------------------------------------------------
%  Primary sources: atomic physics / quantum mechanics
% ---------------------------------------------------------------

@article{Pauli1925,
  author  = {Pauli, Wolfgang},
  title   = {{\"{U}}ber den {Z}usammenhang des {A}bschlusses der
             {E}lektronengruppen im {A}tom mit der
             {K}omplexstruktur der {S}pektren},
  journal = {Zeitschrift f{\"u}r Physik},
  volume  = {31},
  number  = {1},
  pages   = {765--783},
  year    = {1925},
  doi     = {10.1007/BF02980631},
  note    = {The Exclusion Principle paper. Received January 16, 1925.
             Introduces the fourth, two-valued quantum number and the
             rule that no two electrons in an atom share all four
             quantum numbers.  Nobel Prize in Physics, 1945.}
}

@incollection{Pauli1946Nobel,
  author    = {Pauli, Wolfgang},
  title     = {Exclusion Principle and Quantum Mechanics},
  booktitle = {Nobel Lectures, Physics 1942--1962},
  publisher = {Elsevier},
  address   = {Amsterdam},
  year      = {1964},
  pages     = {27--43},
  note      = {Nobel Lecture delivered December 13, 1946 (prize
               awarded 1945). Also available at
               \url{https://www.nobelprize.org/uploads/2018/06/pauli-lecture.pdf}.
               Pauli discusses his reasoning and credits Stoner
               (1924) as the key empirical precursor.}
}

@article{Stoner1924,
  author  = {Stoner, Edmund Clifton},
  title   = {{LXXIII.} The Distribution of Electrons among
             Atomic Levels},
  journal = {The London, Edinburgh, and Dublin Philosophical
             Magazine and Journal of Science},
  volume  = {48},
  number  = {286},
  pages   = {719--736},
  year    = {1924},
  doi     = {10.1080/14786442408634535},
  note    = {Uses X-ray spectroscopic data to show that each
             $m_l$-sublevel in a magnetic field holds two electrons,
             giving subshell capacity $2(2l+1)$ and shell capacity
             $2n^2$.  Read by Pauli as the decisive empirical clue.}
}

@article{UhlenbeckGoudsmit1925,
  author  = {Uhlenbeck, George Eugene and Goudsmit, Samuel Abraham},
  title   = {Ersetzung der {H}ypothese vom unmechanischen {Z}wang
             durch eine {F}orderung bez{\"u}glich des inneren
             {V}erhaltens jedes einzelnen {E}lektrons},
  journal = {Die Naturwissenschaften},
  volume  = {13},
  pages   = {953--954},
  year    = {1925},
  note    = {Proposes intrinsic electron spin $s=\tfrac{1}{2}$ with
             projections $m_s = \pm\tfrac{1}{2}$ and anomalous gyromagnetic
             ratio $g_s \approx 2$.  Gives physical meaning to Pauli's
             fourth quantum number.}
}

@article{UhlenbeckGoudsmit1926,
  author  = {Uhlenbeck, George Eugene and Goudsmit, Samuel Abraham},
  title   = {Spinning Electrons and the Structure of Spectra},
  journal = {Nature},
  volume  = {117},
  pages   = {264--265},
  year    = {1926},
  doi     = {10.1038/117264a0},
  note    = {Longer English-language presentation of the spin
             hypothesis; derives the doublet structure of alkali
             spectra from $g_s = 2$.}
}

@article{Lande1921,
  author  = {Land{\'e}, Alfred},
  title   = {{\"{U}}ber den anomalen {Z}eemaneffekt},
  journal = {Zeitschrift f{\"u}r Physik},
  volume  = {5},
  number  = {4},
  pages   = {231--241},
  year    = {1921},
  doi     = {10.1007/BF01335014},
  note    = {Derives the empirical g-factor formula
             $g_J = 1 + [J(J+1)+S(S+1)-L(L+1)]/[2J(J+1)]$
             from spectroscopic data, before spin was known.
             Half-integer $j$ values were inexplicable in the
             three-quantum-number scheme.}
}

@article{PaschenBack1921,
  author  = {Paschen, Friedrich and Back, Ernst Emil Alexander},
  title   = {Liniengruppen magnetisch vervollst{\"a}ndigt},
  journal = {Physica},
  volume  = {1},
  pages   = {261--273},
  year    = {1921},
  note    = {The Paschen--Back effect: in strong magnetic fields
             the anomalous Zeeman pattern reverts to the normal
             (three-line) pattern as LS coupling breaks down;
             confirmed by the four-quantum-number model.}
}

@article{Fermi1926,
  author  = {Fermi, Enrico},
  title   = {Sulla quantizzazione del gas perfetto monoatomico},
  journal = {Rendiconti dell'Accademia Nazionale dei Lincei},
  volume  = {3},
  pages   = {145--149},
  year    = {1926},
  note    = {First paper on Fermi--Dirac statistics.  The Exclusion
             Principle implies that fermionic occupation numbers are
             restricted to $\{0,1\}$, producing the Fermi distribution
             $\bar n_i = [e^{(\varepsilon_i-\mu)/k_BT}+1]^{-1}$.}
}

@article{Dirac1926,
  author  = {Dirac, Paul Adrien Maurice},
  title   = {On the Theory of Quantum Mechanics},
  journal = {Proceedings of the Royal Society of London,
             Series~{A}},
  volume  = {112},
  number  = {762},
  pages   = {661--677},
  year    = {1926},
  doi     = {10.1098/rspa.1926.0133},
  note    = {Derives Fermi--Dirac statistics independently of Fermi
             from quantum mechanics; also derives Bose--Einstein
             statistics for integer-spin particles, identifying the
             two classes of quantum statistics.}
}

@article{Dirac1928,
  author  = {Dirac, Paul Adrien Maurice},
  title   = {The Quantum Theory of the Electron},
  journal = {Proceedings of the Royal Society of London,
             Series~{A}},
  volume  = {117},
  number  = {778},
  pages   = {610--624},
  year    = {1928},
  doi     = {10.1098/rspa.1928.0023},
  note    = {The Dirac equation.  Spin-$\tfrac{1}{2}$ emerges
             automatically from combining quantum mechanics with
             special relativity; $g_s = 2$ follows without additional
             postulates.  Retroactively derives the fourth quantum
             number from first principles.}
}

@article{Pauli1940,
  author  = {Pauli, Wolfgang},
  title   = {The Connection Between Spin and Statistics},
  journal = {Physical Review},
  volume  = {58},
  pages   = {716--722},
  year    = {1940},
  doi     = {10.1103/PhysRev.58.716},
  note    = {Spin--statistics theorem: in a relativistic quantum
             field theory with locality, causality, and positive
             energy, half-integer-spin particles must obey the
             Exclusion Principle (Fermi--Dirac statistics).
             The exclusion principle is thus a theorem, not a
             postulate, in quantum field theory.}
}

@article{Sommerfeld1916,
  author  = {Sommerfeld, Arnold},
  title   = {Zur {Q}uantentheorie der {S}pektrallinien},
  journal = {Annalen der Physik},
  volume  = {356},
  number  = {17},
  pages   = {1--94},
  year    = {1916},
  doi     = {10.1002/andp.19163561702},
  note    = {Extension of Bohr's model to elliptical orbits using
             action quantization; introduces the azimuthal quantum
             number $k$ (now $l$) and the magnetic quantum number $m_l$.
             Three quantum numbers $(n,l,m_l)$ from this paper
             give $n^2$ states per shell---half the observed $2n^2$.}
}

@article{Bohr1913,
  author  = {Bohr, Niels},
  title   = {On the Constitution of Atoms and Molecules},
  journal = {Philosophical Magazine},
  volume  = {26},
  number  = {151},
  pages   = {1--25},
  year    = {1913},
  doi     = {10.1080/14786441308634955},
  note    = {The original Bohr model.  Quantised circular orbits
             with angular momentum $L = n\hbar$; correctly predicts
             hydrogen energy levels $E_n = -13.6\,\text{eV}/n^2$
             but cannot account for multi-electron atoms or the
             anomalous Zeeman effect.}
}

@article{Zeeman1897,
  author  = {Zeeman, Pieter},
  title   = {On the Influence of Magnetism on the Nature of the
             Light Emitted by a Substance},
  journal = {Philosophical Magazine},
  volume  = {43},
  number  = {262--263},
  pages   = {226--239},
  year    = {1897},
  note    = {Discovery of magnetic splitting of spectral lines.
             Nobel Prize in Physics, 1902 (shared with H.\,A.\,Lorentz).
             The normal (three-line) pattern is consistent with
             classical electron theory; the anomalous (multi-line)
             pattern is not.}
}

@article{Fowler1926,
  author  = {Fowler, Ralph Howard},
  title   = {On Dense Matter},
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume  = {87},
  pages   = {114--122},
  year    = {1926},
  doi     = {10.1093/mnras/87.2.114},
  note    = {First application of Fermi--Dirac statistics to
             astrophysics: electron degeneracy pressure from
             the Exclusion Principle stabilises white dwarf stars
             against gravitational collapse.}
}

@article{Sommerfeld1927,
  author  = {Sommerfeld, Arnold},
  title   = {Zur {E}lektronentheorie der {M}etalle auf {G}rund
             der {F}ermischen {S}tatistik},
  journal = {Zeitschrift f{\"u}r Physik},
  volume  = {47},
  pages   = {1--32},
  year    = {1927},
  doi     = {10.1007/BF01391052},
  note    = {Resolves the old paradox of why conduction electrons
             contribute so little to metallic heat capacity: at
             room temperature only electrons within $k_BT$ of the
             Fermi level can be thermally excited, because the
             Exclusion Principle blocks all states below $E_F$.}
}

